# === Server (Railway / dev local) ===

# Porta (Railway define automaticamente em prod)
PORT=2567

# CORS — origens permitidas (vazio = qualquer, só em dev)
ALLOWED_ORIGINS=http://localhost:5173

# Postgres (Railway injeta DATABASE_URL automaticamente quando você
# adiciona o plugin Postgres). Em dev local, rode:
#   docker run --name pg-gather -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# JWT — segredo pra assinar tokens de sessão (mínimo 16 chars).
# Gerar com: openssl rand -hex 32
JWT_SECRET=troque-isto-em-producao-use-openssl-rand-hex-32

# LiveKit Cloud (projeto "GaTherPrivate")
LIVEKIT_URL=wss://gatherprivate-wj37bvum.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Dashboard /colyseus (basic auth)
MONITOR_USER=admin
MONITOR_PASS=trocar
